NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
APP_ACCESS_TOKEN=mannings

# AI（SenseNova，OpenAI 相容；env var 名保留 OPENROUTER_API_KEY 歷史相容）
OPENROUTER_API_KEY=
AI_MODEL_HEAVY=deepseek-v4-flash
AI_MODEL_FAST=deepseek-v4-flash

# Email 報告（Gmail SA 網域全權委派）
GMAIL_SENDER=dmcommunity@fimmick.com
GOOGLE_SA_KEY_PATH=C:/path/to/sa.json   # 本機開發：SA json 檔路徑
# GOOGLE_SA_CREDENTIALS={...}            # Vercel：改用此 env（SA json 整段字串），勿用檔案路徑
APP_URL=http://localhost:3000           # email 內「開啟看板」連結；Vercel 設成正式網域
# TZ=Asia/Hong_Kong                      # 僅 Vercel 需設（讓伺服器時段運算＝港時）
